# ============================================================
# Hayabusa-FX (hayabusa-plus) — gitignore
# ============================================================

# ── 実行ファイル・ルール ──
# `git clone` だけでそのまま起動できるよう、fork 版バイナリ・config・ルールツリーは
# コミットする (Windows ネイティブ実行・LAN 公開がワンステップで動くように)。
# 除外するのは上流バイナリ (fork 版があれば不要) と実行時ログのみ。
bin/hayabusa-3.9.0-win-x64.exe
bin/logs/

# Rust ビルド成果物
engine/target/
engine/Cargo.lock.bak
**/*.rs.bk

# ── ランタイム / 解析データ ──
# 個別解析の出力・SQLite キャッシュ・EVTX サンプル等は履歴に残さない。
workspace/
logs/

# Lookup テーブルは README に書いた "サンプル" だけ含める。
# 運用で蓄積される TP/FP 履歴は per-team の機密データなので除外。
lookups/fp_history/

# ── OS / IDE ──
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
~$*

# ── Python ──
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# ── DB ローカルキャッシュ (workspace/ 配下なので冗長だが念のため) ──
*.sqlite
*.sqlite-wal
*.sqlite-shm

# ── 一時 ──
*.tmp
*.bak
*~

# ── 大きな or 一時的な EVTX 単独配置を防止 ──
# (チェックインしたい場合は明示的に -f を付ける)
*.evtx
*.json.tmp
/lookups/loldrivers.txt
/lookups/malware_bazaar_sha256.txt
/lookups/urlhaus_urls.txt
/lookups/feodo_c2_ips.txt
/lookups/*.meta.json

# preview server config (local)
.claude/launch.json
dist/
docs/presentation/pptx/_qa/
docs/presentation/pptx/_assets/
~$*.pptx

# プレゼン一式は GitHub では管理しない (ローカルのみ)
docs/presentation/
docs/demo/
